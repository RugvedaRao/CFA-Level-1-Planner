// ═══════════════════════════════════════
// PRACTICE TEST
// ═══════════════════════════════════════
let testMode = 'quick';
let testQuestions = [];
let testIdx = 0;
let testCorrect = 0;
let testAnswered = false;

function selectMode(el) {
  document.querySelectorAll('.config-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  testMode = el.dataset.mode;
}

function startTest() {
  let pool = [...PRACTICE_QUESTIONS];
  if(testMode === 'ethics') pool = pool.filter(q => q.topic === 'Ethics');
  else if(testMode === 'quant') pool = pool.filter(q => q.topic === 'Quant');
  else if(testMode === 'fra') pool = pool.filter(q => q.topic === 'FRA');
  else if(testMode === 'fi') pool = pool.filter(q => q.topic === 'Fixed Income');

  // shuffle
  for(let i = pool.length-1; i > 0; i--) { const j=Math.floor(Math.random()*(i+1)); [pool[i],pool[j]]=[pool[j],pool[i]]; }

  const count = testMode === 'full' ? Math.min(25, pool.length) : Math.min(10, pool.length);
  testQuestions = pool.slice(0, count);
  testIdx = 0;
  testCorrect = 0;

  document.getElementById('testSetup').style.display = 'none';
  document.getElementById('testResults').style.display = 'none';
  document.getElementById('questionBlock').classList.add('visible');
  renderQuestion();
}

function renderQuestion() {
  if(testIdx >= testQuestions.length) { showResults(); return; }
  testAnswered = false;
  const q = testQuestions[testIdx];
  const pct = ((testIdx+1) / testQuestions.length * 100).toFixed(0);

  document.getElementById('qNumLabel').textContent = 'Q ' + (testIdx+1) + '/' + testQuestions.length;
  document.getElementById('qProgressFill').style.width = pct + '%';
  document.getElementById('qScoreLabel').textContent = 'Score: ' + testCorrect + '/' + testIdx;
  document.getElementById('questionText').textContent = q.q;
  document.getElementById('explanationBox').classList.remove('show');
  document.getElementById('nextQBtn').style.display = 'none';

  const opts = document.getElementById('optionsContainer');
  opts.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const div = document.createElement('div');
    div.className = 'option';
    div.innerHTML = `<div class="opt-letter">${String.fromCharCode(65+i)}</div><div class="opt-text">${opt}</div>`;
    div.onclick = () => selectAnswer(i, q, div);
    opts.appendChild(div);
  });
}

function selectAnswer(i, q, el) {
  if(testAnswered) return;
  testAnswered = true;
  const opts = document.querySelectorAll('.option');
  opts[q.ans].classList.add('correct');
  if(i !== q.ans) el.classList.add('wrong');
  else { testCorrect++; addXP(5); }
  const exp = document.getElementById('explanationBox');
  exp.innerHTML = '<strong>Explanation:</strong> ' + q.exp;
  exp.classList.add('show');
  document.getElementById('nextQBtn').style.display = 'block';
  state.attemptedTotal++;
  state.correctTotal += (i === q.ans ? 1 : 0);
  saveState();
  updateStats();
}

function nextQuestion() {
  testIdx++;
  renderQuestion();
}

function showResults() {
  document.getElementById('questionBlock').classList.remove('visible');
  document.getElementById('testResults').style.display = 'block';
  const score = testQuestions.length > 0 ? Math.round(testCorrect/testQuestions.length*100) : 0;
  const xpEarned = testCorrect * 5;
  document.getElementById('resultScore').textContent = score + '%';
  document.getElementById('resultCorrect').textContent = testCorrect + '/' + testQuestions.length;
  document.getElementById('resultXP').textContent = '+' + xpEarned;
  const msg = score >= 70 ? '🎉 Great job! Passing score reached.' : score >= 50 ? '📚 Keep practising — you\'re getting there.' : '💪 Review the material and try again.';
  document.getElementById('resultSubtitle').textContent = msg;
}

function endTest() {
  document.getElementById('questionBlock').classList.remove('visible');
  document.getElementById('testSetup').style.display = 'block';
}

function restartTest() {
  document.getElementById('testResults').style.display = 'none';
  document.getElementById('testSetup').style.display = 'block';
}

// ═══════════════════════════════════════
// POMODORO TIMER
// ═══════════════════════════════════════
let pomDuration = 25 * 60;
let pomRemaining = 25 * 60;
let pomRunning = false;
let pomInterval = null;
let pomLabel = 'Focus session — 25 minutes';

let sessRunning = false;
let sessInterval = null;
let sessSeconds = 0;
let sessLogs = [];

function togglePomodoro() {
  if(pomRunning) {
    clearInterval(pomInterval);
    pomRunning = false;
    document.getElementById('pomStartBtn').textContent = '▶ Resume';
  } else {
    pomRunning = true;
    document.getElementById('pomStartBtn').textContent = '⏸ Pause';
    pomInterval = setInterval(() => {
      pomRemaining--;
      renderPomodoro();
      if(pomRemaining <= 0) {
        clearInterval(pomInterval);
        pomRunning = false;
        document.getElementById('pomStartBtn').textContent = '▶ Start';
        document.getElementById('pomStatus').textContent = '✅ Session complete! Take a break.';
        addXP(10);
      }
    }, 1000);
  }
}

function renderPomodoro() {
  const m = Math.floor(pomRemaining/60);
  const s = pomRemaining % 60;
  document.getElementById('pomH').textContent = String(m).padStart(2,'0');
  document.getElementById('pomS').textContent = String(s).padStart(2,'0');
  document.getElementById('pomStatus').textContent = pomLabel;
}

function resetPomodoro() {
  clearInterval(pomInterval);
  pomRunning = false;
  pomRemaining = pomDuration;
  renderPomodoro();
  document.getElementById('pomStartBtn').textContent = '▶ Start';
}

function setPomDuration(mins, label) {
  pomDuration = mins * 60;
  pomLabel = label;
  resetPomodoro();
}

function toggleSession() {
  if(sessRunning) {
    clearInterval(sessInterval);
    sessRunning = false;
    document.getElementById('sessStartBtn').textContent = '▶ Continue';
    // log it
    const mins = Math.floor(sessSeconds / 60);
    if(mins > 0) {
      sessLogs.push({ mins, time: new Date().toLocaleTimeString() });
      state.studySeconds += sessSeconds;
      saveState();
      updateStats();
      renderSessionLog();
      updateLifetimeTime();
    }
  } else {
    sessRunning = true;
    sessSeconds = 0;
    document.getElementById('sessStartBtn').textContent = '⏸ Pause';
    sessInterval = setInterval(() => {
      sessSeconds++;
      const h = Math.floor(sessSeconds/3600);
      const m = Math.floor((sessSeconds%3600)/60);
      const s = sessSeconds%60;
      document.getElementById('sessH').textContent = String(h).padStart(2,'0');
      document.getElementById('sessM').textContent = String(m).padStart(2,'0');
      document.getElementById('sessS').textContent = String(s).padStart(2,'0');
    }, 1000);
  }
}

function resetSession() {
  clearInterval(sessInterval);
  sessRunning = false;
  sessSeconds = 0;
  document.getElementById('sessH').textContent = '00';
  document.getElementById('sessM').textContent = '00';
  document.getElementById('sessS').textContent = '00';
  document.getElementById('sessStartBtn').textContent = '▶ Start Session';
}

function renderSessionLog() {
  const log = document.getElementById('sessionLog');
  if(!sessLogs.length) {
    log.innerHTML = '<div style="font-size:13px; color:var(--text3); padding:16px 0">No sessions logged yet.</div>';
    return;
  }
  log.innerHTML = sessLogs.slice(-5).reverse().map(l =>
    `<div style="display:flex; align-items:center; gap:14px; padding:12px 16px; background:var(--surface); border:1px solid var(--border); border-radius:10px;">
      <span style="font-size:20px">⏱</span>
      <div style="flex:1">
        <div style="font-size:14px; font-weight:600">${l.mins} minute session</div>
        <div style="font-size:12px; color:var(--text3)">${l.time}</div>
      </div>
      <div style="font-size:13px; font-weight:700; color:var(--gold)">+${l.mins >= 25 ? 10 : 5} XP</div>
    </div>`
  ).join('');
}

function updateLifetimeTime() {
  const total = state.studySeconds;
  const h = Math.floor(total/3600);
  const m = Math.floor((total%3600)/60);
  document.getElementById('lifetimeTime').textContent = h + 'h ' + m + 'm';
}

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
buildTopicsGrid();
buildFormulas();
renderCard();
updateLifetimeTime();

// restore flash stats
const fs = state.flashStats;
document.getElementById('statAgain').textContent = fs.again;
document.getElementById('statHard').textContent = fs.hard;
document.getElementById('statGood').textContent = fs.good;
document.getElementById('statEasy').textContent = fs.easy;

// streak logic
const today = new Date().toDateString();
if(state.lastDate !== today) {
  const yesterday = new Date(Date.now() - 86400000).toDateString();
  state.streak = (state.lastDate === yesterday) ? state.streak + 1 : 1;
  state.lastDate = today;
  saveState();
}
document.getElementById('streakCount').textContent = state.streak;
document.getElementById('xpDisplay').textContent = state.xp;
</script>
</body>
</html>
