<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CFA Level 1 — Study Hub</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c10;
    --surface: #111318;
    --surface2: #181c24;
    --surface3: #1e2330;
    --border: #252b38;
    --border2: #2e3647;
    --text: #e8eaf0;
    --text2: #8b93a8;
    --text3: #555f74;
    --accent: #4f8ef7;
    --accent2: #7c5cfc;
    --gold: #f0b429;
    --gold2: #e8931a;
    --green: #34d399;
    --red: #f87171;
    --orange: #fb923c;

    --ethics: #4f8ef7;
    --quant: #7c5cfc;
    --econ: #34d399;
    --fra: #f0b429;
    --corp: #fb923c;
    --equity: #f472b6;
    --fi: #60a5fa;
    --deriv: #a78bfa;
    --alt: #4ade80;
    --port: #fbbf24;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Manrope', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 600px 400px at 10% 20%, rgba(79,142,247,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 400px 600px at 90% 80%, rgba(124,92,252,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 300px 300px at 50% 50%, rgba(240,180,41,0.03) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  #app { position: relative; z-index: 1; }

  /* ── HEADER ── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    border-bottom: 1px solid var(--border);
    background: rgba(10,12,16,0.8);
    backdrop-filter: blur(16px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-badge {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'DM Serif Display', serif;
    font-size: 16px; color: white; font-weight: 700;
  }

  .logo-text {
    font-family: 'DM Serif Display', serif;
    font-size: 18px;
    letter-spacing: -0.3px;
  }

  .logo-text span { color: var(--gold); }

  nav { display: flex; gap: 4px; }

  .nav-btn {
    padding: 8px 16px;
    border: none;
    background: transparent;
    color: var(--text2);
    font-family: 'Manrope', sans-serif;
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }

  .nav-btn:hover { background: var(--surface2); color: var(--text); }
  .nav-btn.active { background: var(--surface3); color: var(--accent); }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .xp-badge {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px;
    background: rgba(240,180,41,0.1);
    border: 1px solid rgba(240,180,41,0.2);
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
  }

  .streak {
    display: flex; align-items: center; gap: 5px;
    font-size: 13px; font-weight: 700;
    color: var(--orange);
  }

  /* ── MAIN ── */
  main { padding: 40px; max-width: 1400px; margin: 0 auto; }

  /* ── VIEWS ── */
  .view { display: none; animation: fadeIn 0.3s ease; }
  .view.active { display: block; }

  @keyframes fadeIn { from { opacity:0; transform: translateY(8px); } to { opacity:1; transform:none; } }

  /* ── HERO STATS ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  }

  .stat-card:hover { transform: translateY(-2px); border-color: var(--border2); }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }

  .stat-card.blue::before { background: linear-gradient(90deg, var(--accent), transparent); }
  .stat-card.purple::before { background: linear-gradient(90deg, var(--accent2), transparent); }
  .stat-card.gold::before { background: linear-gradient(90deg, var(--gold), transparent); }
  .stat-card.green::before { background: linear-gradient(90deg, var(--green), transparent); }

  .stat-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text3); margin-bottom: 10px; }
  .stat-value { font-size: 36px; font-family: 'DM Serif Display', serif; color: var(--text); line-height: 1; margin-bottom: 6px; }
  .stat-sub { font-size: 12px; color: var(--text2); }

  /* ── PROGRESS BAR ── */
  .progress-bar {
    width: 100%; height: 6px;
    background: var(--surface3);
    border-radius: 99px;
    overflow: hidden;
    margin-top: 10px;
  }

  .progress-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 1s ease;
  }

  /* ── TOPIC GRID ── */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
  }

  .section-title span { color: var(--text3); font-size: 14px; font-family: 'Manrope', sans-serif; margin-left: 8px; font-weight: 500; }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin-bottom: 36px;
  }

  .topic-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .topic-card:hover {
    border-color: var(--border2);
    transform: translateY(-2px);
    background: var(--surface2);
  }

  .topic-card.expanded { border-color: var(--border2); }

  .topic-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .topic-icon {
    width: 42px; height: 42px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .topic-info { flex: 1; min-width: 0; }
  .topic-name { font-size: 15px; font-weight: 700; margin-bottom: 3px; }
  .topic-weight { font-size: 11px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.8px; }

  .topic-progress-wrap {
    display: flex; align-items: center; gap: 10px;
    margin-top: 12px;
  }

  .topic-pct { font-size: 13px; font-weight: 700; font-family: 'DM Mono', monospace; min-width: 36px; text-align: right; }

  .subtopics {
    display: none;
    margin-top: 16px;
    border-top: 1px solid var(--border);
    padding-top: 16px;
    gap: 8px;
    flex-direction: column;
  }

  .topic-card.expanded .subtopics { display: flex; }

  .subtopic-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 12px;
    border-radius: 8px;
    background: var(--surface3);
    cursor: pointer;
    transition: background 0.15s;
    gap: 10px;
  }

  .subtopic-row:hover { background: var(--border); }

  .subtopic-name { font-size: 13px; font-weight: 500; flex: 1; }

  .subtopic-status {
    width: 20px; height: 20px;
    border-radius: 6px;
    border: 2px solid var(--border2);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .subtopic-row.done .subtopic-status {
    background: var(--green);
    border-color: var(--green);
    color: #000;
  }

  .subtopic-row.review .subtopic-status {
    background: var(--gold);
    border-color: var(--gold);
    color: #000;
  }

  /* ── FLASHCARD VIEW ── */
  .flashcard-controls {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .topic-filter {
    display: flex; gap: 8px; flex-wrap: wrap;
  }

  .filter-pill {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border2);
    background: transparent;
    color: var(--text2);
    font-family: 'Manrope', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-pill:hover { background: var(--surface2); color: var(--text); }
  .filter-pill.active { background: var(--accent); border-color: var(--accent); color: white; }

  .flashcard-arena {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .flashcard-counter {
    font-size: 13px;
    color: var(--text3);
    font-family: 'DM Mono', monospace;
  }

  .flashcard-wrap {
    width: 100%;
    max-width: 680px;
    perspective: 1200px;
  }

  .flashcard {
    width: 100%; height: 320px;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
  }

  .flashcard.flipped { transform: rotateY(180deg); }

  .card-face {
    position: absolute; inset: 0;
    border-radius: 20px;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 36px;
    text-align: center;
  }

  .card-front {
    background: var(--surface);
    border: 1px solid var(--border2);
  }

  .card-back {
    background: linear-gradient(135deg, var(--surface2), var(--surface3));
    border: 1px solid var(--border2);
    transform: rotateY(180deg);
  }

  .card-tag {
    position: absolute;
    top: 16px; left: 20px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    padding: 4px 10px;
    border-radius: 99px;
    color: white;
  }

  .card-hint {
    position: absolute;
    bottom: 16px; right: 20px;
    font-size: 11px;
    color: var(--text3);
    font-style: italic;
  }

  .card-q {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    line-height: 1.4;
    color: var(--text);
  }

  .card-a {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
  }

  .card-a strong { color: var(--accent); }

  .flashcard-nav {
    display: flex; align-items: center; gap: 12px;
  }

  .nav-icon-btn {
    width: 44px; height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--text2);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    transition: all 0.2s;
  }

  .nav-icon-btn:hover { background: var(--surface2); color: var(--text); border-color: var(--accent); }

  .rate-btns {
    display: flex; gap: 10px;
  }

  .rate-btn {
    padding: 10px 24px;
    border-radius: 12px;
    border: none;
    font-family: 'Manrope', sans-serif;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .rate-again { background: rgba(248,113,113,0.15); color: var(--red); border: 1px solid rgba(248,113,113,0.3); }
  .rate-hard { background: rgba(251,146,60,0.15); color: var(--orange); border: 1px solid rgba(251,146,60,0.3); }
  .rate-good { background: rgba(52,211,153,0.15); color: var(--green); border: 1px solid rgba(52,211,153,0.3); }
  .rate-easy { background: rgba(79,142,247,0.15); color: var(--accent); border: 1px solid rgba(79,142,247,0.3); }

  .rate-btn:hover { transform: translateY(-2px); filter: brightness(1.2); }

  /* ── FORMULA SHEET ── */
  .formula-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .formula-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    transition: all 0.2s;
  }

  .formula-card:hover { border-color: var(--border2); transform: translateY(-2px); }

  .formula-topic {
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 8px;
    padding: 3px 10px;
    border-radius: 99px;
    display: inline-block;
    color: white;
  }

  .formula-name { font-size: 14px; font-weight: 700; margin-bottom: 10px; color: var(--text); }

  .formula-expr {
    background: var(--surface3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--gold);
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .formula-note { font-size: 12px; color: var(--text3); margin-top: 8px; line-height: 1.5; }

  /* ── TIMER ── */
  .timer-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 36px;
  }

  .timer-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    text-align: center;
  }

  .timer-display {
    font-family: 'DM Serif Display', serif;
    font-size: 64px;
    color: var(--text);
    letter-spacing: -2px;
    line-height: 1;
    margin: 20px 0;
  }

  .timer-display span { color: var(--accent); }

  .timer-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

  .timer-btn {
    padding: 10px 24px;
    border-radius: 10px;
    border: 1px solid var(--border2);
    background: var(--surface2);
    color: var(--text);
    font-family: 'Manrope', sans-serif;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .timer-btn:hover { background: var(--accent); border-color: var(--accent); color: white; }
  .timer-btn.primary { background: var(--accent); border-color: var(--accent); color: white; }
  .timer-btn.danger { background: rgba(248,113,113,0.15); border-color: rgba(248,113,113,0.3); color: var(--red); }

  /* ── MOCK TEST ── */
  .test-config {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }

  .config-card {
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }

  .config-card:hover { border-color: var(--accent); }
  .config-card.selected { border-color: var(--accent); background: rgba(79,142,247,0.08); }

  .config-icon { font-size: 28px; margin-bottom: 10px; }
  .config-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
  .config-desc { font-size: 12px; color: var(--text3); }

  .start-test-btn {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%;
    padding: 16px;
    border-radius: 14px;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: white;
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }

  .start-test-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(79,142,247,0.3); }

  /* ── QUESTION BLOCK ── */
  .question-block { display: none; }
  .question-block.visible { display: block; }

  .q-progress-bar {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px;
  }

  .q-num { font-family: 'DM Mono', monospace; font-size: 13px; color: var(--text3); min-width: 60px; }

  .question-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 16px;
  }

  .question-text { font-size: 16px; line-height: 1.7; color: var(--text); margin-bottom: 20px; font-weight: 500; }

  .options { display: flex; flex-direction: column; gap: 10px; }

  .option {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.15s;
    background: var(--surface2);
  }

  .option:hover { border-color: var(--accent); background: rgba(79,142,247,0.06); }
  .option.selected { border-color: var(--accent); background: rgba(79,142,247,0.1); }
  .option.correct { border-color: var(--green); background: rgba(52,211,153,0.1); }
  .option.wrong { border-color: var(--red); background: rgba(248,113,113,0.1); }

  .opt-letter {
    width: 24px; height: 24px;
    border-radius: 6px;
    background: var(--surface3);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700;
    font-family: 'DM Mono', monospace;
    flex-shrink: 0;
    color: var(--text2);
    transition: all 0.15s;
  }

  .option.selected .opt-letter { background: var(--accent); color: white; }
  .option.correct .opt-letter { background: var(--green); color: #000; }
  .option.wrong .opt-letter { background: var(--red); color: white; }

  .opt-text { font-size: 14px; line-height: 1.5; color: var(--text2); }
  .option.selected .opt-text, .option.correct .opt-text { color: var(--text); }

  .explanation {
    display: none;
    background: rgba(52,211,153,0.06);
    border: 1px solid rgba(52,211,153,0.2);
    border-radius: 10px;
    padding: 16px;
    margin-top: 14px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--text2);
  }

  .explanation.show { display: block; }
  .explanation strong { color: var(--green); }

  .q-actions { display: flex; justify-content: space-between; align-items: center; }

  .btn {
    padding: 10px 24px;
    border-radius: 10px;
    border: 1px solid var(--border2);
    background: var(--surface2);
    color: var(--text);
    font-family: 'Manrope', sans-serif;
    font-size: 13px; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
  }

  .btn:hover { background: var(--surface3); border-color: var(--text3); }
  .btn.primary { background: var(--accent); border-color: var(--accent); color: white; }
  .btn.primary:hover { filter: brightness(1.1); }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 99px; }

  /* ── TAGS on topics ── */
  .tag { display: inline-block; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    header { padding: 14px 20px; }
    main { padding: 20px; }
    .hero-grid { grid-template-columns: 1fr 1fr; }
    .topics-grid { grid-template-columns: 1fr; }
    .formula-grid { grid-template-columns: 1fr 1fr; }
    .test-config { grid-template-columns: 1fr 1fr; }
    .timer-section { grid-template-columns: 1fr; }
    nav { display: none; }
  }

  @media (max-width: 600px) {
    .hero-grid { grid-template-columns: 1fr; }
    .formula-grid { grid-template-columns: 1fr; }
    .test-config { grid-template-columns: 1fr; }
    .flashcard .card-q { font-size: 17px; }
    .timer-display { font-size: 48px; }
  }
</style>
</head>
<body>
<div id="app">

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-badge">CFA</div>
    <div class="logo-text">Study<span>Hub</span> Level I</div>
  </div>
  <nav>
    <button class="nav-btn active" onclick="showView('dashboard')">Dashboard</button>
    <button class="nav-btn" onclick="showView('flashcards')">Flashcards</button>
    <button class="nav-btn" onclick="showView('formulas')">Formulas</button>
    <button class="nav-btn" onclick="showView('practice')">Practice</button>
    <button class="nav-btn" onclick="showView('timer')">Study Timer</button>
  </nav>
  <div class="header-right">
    <div class="streak" id="streakDisplay">🔥 <span id="streakCount">0</span>d streak</div>
    <div class="xp-badge">⭐ <span id="xpDisplay">0</span> XP</div>
  </div>
</header>

<main>

<!-- ══════════════════════════════════════════════
     DASHBOARD VIEW
══════════════════════════════════════════════ -->
<div class="view active" id="view-dashboard">

  <div class="hero-grid">
    <div class="stat-card blue">
      <div class="stat-label">Overall Progress</div>
      <div class="stat-value" id="overallPct">0%</div>
      <div class="stat-sub" id="subtopicsDone">0 / 0 topics completed</div>
