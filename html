// FLASHCARDS
// ═══════════════════════════════════════
let flashDeck = [...FLASHCARDS];
let flashIdx = 0;
let flashFlipped = false;

function setFlashFilter(filter, btn) {
  document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  flashDeck = filter === 'all' ? [...FLASHCARDS] : FLASHCARDS.filter(c => c.topic === filter);
  flashIdx = 0;
  renderCard();
}

function renderCard() {
  if(!flashDeck.length) return;
  const card = flashDeck[flashIdx];
  const color = TOPIC_COLORS[card.topic] || '#4f8ef7';
  document.getElementById('cardQ').textContent = card.q;
  document.getElementById('cardA').innerHTML = card.a;
  document.getElementById('cardTag').textContent = card.topic;
  document.getElementById('cardTagB').textContent = card.topic;
  document.getElementById('cardTag').style.background = color;
  document.getElementById('cardTagB').style.background = color;
  document.getElementById('flashCounter').textContent = 'Card ' + (flashIdx+1) + ' of ' + flashDeck.length;
  // unflip
  const fc = document.getElementById('mainCard');
  fc.classList.remove('flipped');
  flashFlipped = false;
  document.getElementById('rateBtns').style.display = 'none';
}

function flipCard() {
  const fc = document.getElementById('mainCard');
  fc.classList.toggle('flipped');
  flashFlipped = !flashFlipped;
  document.getElementById('rateBtns').style.display = flashFlipped ? 'flex' : 'none';
  if(flashFlipped) {
    state.cardsReviewed++;
    saveState();
    updateStats();
  }
}

function prevCard() {
  flashIdx = (flashIdx - 1 + flashDeck.length) % flashDeck.length;
  renderCard();
}

function nextCard() {
  flashIdx = (flashIdx + 1) % flashDeck.length;
  renderCard();
}

function rateCard(rating) {
  state.flashStats[rating]++;
  document.getElementById('stat' + rating.charAt(0).toUpperCase() + rating.slice(1)).textContent = state.flashStats[rating];
  if(rating === 'good' || rating === 'easy') addXP(2);
  saveState();
  nextCard();
}

