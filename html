function buildTopicsGrid() {
  const grid = document.getElementById('topicsGrid');
  grid.innerHTML = '';
  TOPICS.forEach(topic => {
    const total = topic.subtopics.length;
    const done = topic.subtopics.filter((_,i) => state.subtopics[topic.id+'_'+i] === 'done').length;
    const pct = total > 0 ? Math.round(done/total*100) : 0;
    const color = `var(${topic.color})`;

    const card = document.createElement('div');
    card.className = 'topic-card';
    card.id = 'topic_' + topic.id;

    const subtopicRows = topic.subtopics.map((sub, i) => {
      const key = topic.id+'_'+i;
      const status = state.subtopics[key] || '';
      return `<div class="subtopic-row ${status}" onclick="toggleSubtopic('${key}', event)">
        <span class="subtopic-name">${sub}</span>
        <div class="subtopic-status">${status === 'done' ? '✓' : status === 'review' ? '★' : ''}</div>
      </div>`;
    }).join('');

    card.innerHTML = `
      <div class="topic-header" onclick="toggleExpand('${topic.id}')">
        <div class="topic-icon" style="background: ${color}22; color: ${color}">${topic.icon}</div>
        <div class="topic-info">
          <div class="topic-name">${topic.name}</div>
          <div class="topic-weight">${topic.weight} exam weight · ${total} readings</div>
        </div>
        <div class="topic-pct" style="color:${color}">${pct}%</div>
      </div>
      <div class="topic-progress-wrap">
        <div class="progress-bar" style="flex:1"><div class="progress-fill" style="background:${color}; width:${pct}%"></div></div>
        <div style="font-size:11px; color:var(--text3)">${done}/${total}</div>
      </div>
      <div class="subtopics">${subtopicRows}</div>
    `;
    grid.appendChild(card);
  });
  updateStats();
}

function toggleExpand(id) {
  const card = document.getElementById('topic_' + id);
  card.classList.toggle('expanded');
}

function toggleSubtopic(key, e) {
  e.stopPropagation();
  const row = e.currentTarget;
  const cur = state.subtopics[key] || '';
  if(cur === '') { state.subtopics[key] = 'review'; addXP(1); }
  else if(cur === 'review') { state.subtopics[key] = 'done'; addXP(4); }
  else { state.subtopics[key] = ''; }
  saveState();
  buildTopicsGrid();
  const card = document.getElementById('topic_' + key.split('_')[0]);
  if(card) card.classList.add('expanded');
}

function updateStats() {
  const allSubs = TOPICS.reduce((a,t) => a + t.subtopics.length, 0);
  const doneSubs = Object.values(state.subtopics).filter(v => v === 'done').length;
  const pct = allSubs > 0 ? Math.round(doneSubs/allSubs*100) : 0;

  document.getElementById('overallPct').textContent = pct + '%';
  document.getElementById('subtopicsDone').textContent = doneSubs + ' / ' + allSubs + ' topics completed';
  document.getElementById('overallBar').style.width = pct + '%';

  document.getElementById('cardsReviewed').textContent = state.cardsReviewed;
  document.getElementById('cardsBar').style.width = Math.min(state.cardsReviewed / FLASHCARDS.length * 100, 100) + '%';

  if(state.attemptedTotal > 0) {
    const score = Math.round(state.correctTotal / state.attemptedTotal * 100);
    document.getElementById('avgScore').textContent = score + '%';
    document.getElementById('questionsAttempted').textContent = state.attemptedTotal + ' questions attempted';
  }

  const h = Math.floor(state.studySeconds / 3600);
  const m = Math.floor((state.studySeconds % 3600) / 60);
  document.getElementById('studyTimeDisplay').textContent = h > 0 ? h + 'h ' + m + 'm' : m + 'm';

  document.getElementById('xpDisplay').textContent = state.xp;
  document.getElementById('streakCount').textContent = state.streak;
}

function markAllDone() {
  TOPICS.forEach(t => t.subtopics.forEach((_,i) => { state.subtopics[t.id+'_'+i] = 'done'; }));
  state.xp = Math.max(state.xp, 500);
  saveState();
  buildTopicsGrid();
}

function resetProgress() {
  if(!confirm('Reset all progress?')) return;
  state.subtopics = {};
  state.xp = 0;
  state.cardsReviewed = 0;
  state.correctTotal = 0;
  state.attemptedTotal = 0;
  state.studySeconds = 0;
  state.flashStats = { again:0, hard:0, good:0, easy:0 };
  saveState();
  buildTopicsGrid();
}

